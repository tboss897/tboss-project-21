# Django Settings
SECRET_KEY=replace-with-50-char-random-string
DEBUG=False
BACKEND_HOST=your-app.railway.app

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[pw]@db.[ref].supabase.co:5432/postgres

# Redis (Upstash)
REDIS_URL=rediss://default:[pw]@[host].upstash.io:6379
REDIS_PASSWORD=

# Frontend URL (Vercel) — used for CORS
FRONTEND_URL=https://your-app.vercel.app

# JWT Settings
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=10080

# QR Code Signing
QR_HMAC_SECRET=replace-with-random-secret

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
PAYMENT_RATE_LIMIT_PER_MINUTE=10

# Firebase
FIREBASE_SERVER_KEY=
FIREBASE_CREDENTIALS_PATH=

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@smartschoolwallet.com

# Africa's Talking SMS
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=
